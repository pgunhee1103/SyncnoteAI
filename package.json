{
  "name": "sync-note-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n WEB,COLLAB \"pnpm dev:web\" \"pnpm dev:collab\"",
    "dev:web": "next dev",
    "dev:collab": "tsx watch collaboration-server.ts",
    "build": "next build",
    "start:web": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "start:collab": "cross-env NODE_ENV=production tsx collaboration-server.ts",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/core": "3.27.1",
    "@tiptap/extension-collaboration": "3.27.1",
    "@tiptap/extension-image": "3.27.1",
    "@tiptap/extension-placeholder": "3.27.1",
    "@tiptap/pm": "3.27.1",
    "@tiptap/react": "3.27.1",
    "@tiptap/starter-kit": "3.27.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4",
    "y-protocols": "1.0.7",
    "yjs": "13.6.31",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.5.15",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.9.0"
}
